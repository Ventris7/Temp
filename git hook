#!/bin/bash

# Получаем имя ветки, в которую был сделан push
read oldrev newrev refname

# Проверяем, что push был в ветку master
if [[ "$refname" =~ .*/master$ ]]; then
    echo "Push в ветку master, начинаем деплой..."

    # Устанавливаем переменные
    APP_NAME="myapp"  # Название приложения
    DEPLOY_DIR="/path/to/deploy/directory"  # Папка для деплоя
    BUILD_DIR="/path/to/build/directory"  # Папка для сборки
    SERVICE_NAME="myapp.service"  # Название systemd сервиса

    # 1. Выполнить юнит тесты
    echo "Запуск юнит-тестов..."
    dotnet test

    # Проверяем успешность выполнения тестов
    if [ $? -ne 0 ]; then
      echo "Юнит-тесты не прошли. Деплой отменен."
      exit 1
    fi

    # 2. Публикуем приложение
    echo "Публикация приложения..."
    dotnet publish -c Release -o $BUILD_DIR

    # Проверяем успешность публикации
    if [ $? -ne 0 ]; then
      echo "Ошибка при публикации приложения. Деплой отменен."
      exit 1
    fi

    # 3. Копирование опубликованного приложения в папку деплоя
    echo "Копирование файлов в директорию деплоя..."
    rm -rf $DEPLOY_DIR/*  # Очистим старую папку деплоя перед копированием
    cp -r $BUILD_DIR/* $DEPLOY_DIR/

    # 4. Перезапуск сервиса
    echo "Перезапуск сервиса..."
    sudo systemctl stop $SERVICE_NAME  # Останавливаем текущий сервис
    sudo systemctl start $SERVICE_NAME  # Запускаем сервис снова

    # Проверяем успешность запуска
    if [ $? -ne 0 ]; then
      echo "Ошибка при перезапуске сервиса. Деплой не удался."
      exit 1
    fi

    echo "Деплой завершен успешно!"
else
    echo "Push не был в ветку master. Деплой не будет выполнен."
fi
